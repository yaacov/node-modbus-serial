{
  "tags": {
    "allowUnknownTags": true
  },
  "source": {
    "include": [
      "README.md",
      "apis",
      "ports",
      "servers",
      "utils"
    ]
  },
  "plugins": [
    "plugins/markdown"
  ],
  "opts": {
    "encoding": "utf8",
    "destination": "./docs/gen",
    "recurse": true,
    "template": "./node_modules/clean-jsdoc-theme",
    "theme_opts": {
      "title": "modbus-serial",
      "homepageTitle": "modbus-serial",
      "default_theme": "light"
    }
  },
  "markdown": {
    "hardwrap": false,
    "idInHeadings": true
  }
}
